resource "random_id" "server_RANDOMID" {
  keepers = {
    # Generate a new id each time we switch to a new AMI id
    ami_id = "${var.base_ami_id}"
  }

  byte_length = 8
}

resource "aws_instance" "staging_pr_cicd_demo_RANDOMID" {
  # Read the AMI id "through" the random_id resource to ensure that
  # both will change together.
  ami                    = random_id.server_RANDOMID.keepers.ami_id
  instance_type          = "t3.micro"
  vpc_security_group_ids = ["sg-00f48e397ba8b9abc"]
  key_name               = aws_key_pair.staging_pr_key.key_name

  tags = {
    "Name" = "staging_pr_cicd_demo-RANDOMID"
  }
}

output "staging_pr_dns_RANDOMID" {
  value = aws_instance.staging_pr_cicd_demo_RANDOMID.public_dns
}
